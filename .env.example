# Database Configuration
DATABASE_URL=postgresql://depart_user:depart_secure_password@localhost:5432/depart
DB_PASSWORD=depart_secure_password

# API Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# LLM Configuration (Optional - for Claude-powered features)
ANTHROPIC_API_KEY=

# Web Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Feature Flags
ENABLE_RAG=true
ENABLE_BENCHMARKING=true
ENABLE_PERMISSION_ANALYSIS=true
