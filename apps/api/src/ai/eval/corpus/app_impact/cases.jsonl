{"id": "rownum-medium", "description": "ROWNUM in a SELECT — must explain the LIMIT vs ROW_NUMBER distinction", "inputs": {"schema_summary": "TABLE employees (id, name, dept_id)", "findings": [{"code": "APP.SQL.ROWNUM", "file": "src/Repo.java", "line": 17, "snippet": "SELECT * FROM employees WHERE ROWNUM <= 10", "suggestion": "Replace ROWNUM with ROW_NUMBER() OVER (ORDER BY ...) or LIMIT."}]}, "rules": [{"json_must_have_keys": ["findings"]}, {"json_array_min_len": {"findings": 1}}, {"json_path_equals": {"findings.0.code": "APP.SQL.ROWNUM"}}, {"must_contain": ["LIMIT", "ROW_NUMBER"]}, {"must_not_contain": ["might want to consider", "may want to"]}]}
{"id": "nvl-medium", "description": "NVL in app SQL — must suggest COALESCE with concrete code", "inputs": {"schema_summary": "TABLE employees (id, name, manager_id)", "findings": [{"code": "APP.SQL.FN.NVL", "file": "src/Repo.py", "line": 42, "snippet": "SELECT NVL(name, '<unknown>') FROM employees", "suggestion": "Replace NVL(x, y) with COALESCE(x, y)."}]}, "rules": [{"json_must_have_keys": ["findings"]}, {"json_path_equals": {"findings.0.code": "APP.SQL.FN.NVL"}}, {"must_contain": ["COALESCE"]}, {"must_not_contain": ["might want", "could potentially"]}]}
{"id": "dblink-critical", "description": "Database link — must call out postgres_fdw or app-side join", "inputs": {"schema_summary": "TABLE local_t (id)", "findings": [{"code": "APP.SQL.DBLINK", "file": "src/Pull.java", "line": 88, "snippet": "INSERT INTO local_t SELECT * FROM remote_t@prod_link", "suggestion": "Replace database links with postgres_fdw or move the join into the application."}]}, "rules": [{"json_must_have_keys": ["findings"]}, {"json_path_equals": {"findings.0.code": "APP.SQL.DBLINK"}}, {"must_contain": ["postgres_fdw"]}]}
{"id": "merge-high", "description": "MERGE — must mention PG 15+ MERGE or INSERT ON CONFLICT alternative", "inputs": {"schema_summary": "TABLE orders (id, status)", "findings": [{"code": "APP.SQL.MERGE", "file": "src/Sync.java", "line": 5, "snippet": "MERGE INTO orders t USING staging s ON (t.id = s.id) WHEN MATCHED THEN UPDATE SET t.status = s.status", "suggestion": "PG 15+ supports MERGE; on PG 14, rewrite as INSERT ... ON CONFLICT."}]}, "rules": [{"json_must_have_keys": ["findings"]}, {"must_contain": ["MERGE", "ON CONFLICT"]}]}
{"id": "outer-join-plus-critical", "description": "(+) join — must rewrite as ANSI LEFT/RIGHT JOIN", "inputs": {"schema_summary": "TABLE orders (id, customer_id), TABLE customers (id, name)", "findings": [{"code": "APP.SQL.OUTER_JOIN_PLUS", "file": "src/orders_repo.py", "line": 12, "snippet": "SELECT o.id, c.name FROM orders o, customers c WHERE o.customer_id = c.id(+)", "suggestion": "Rewrite (+) outer joins as ANSI LEFT/RIGHT OUTER JOIN."}]}, "rules": [{"json_must_have_keys": ["findings"]}, {"must_contain": ["LEFT", "JOIN"]}, {"must_not_contain": ["(+)"]}]}
